   <property name="styleSheet">
    <string notr="true">QGroupBox
{
	color: yellow;
	background-color: rgb(36, 31, 49);
	border: 1px solid silver;
	border-radius: 4px;
	font-weight: bold;

	padding-top: 1em;
}
QGroupBox:flat
{
	background-color: rgb(23, 64, 25);
}
QGroupBox::title
{
	subcontrol-origin: padding;
	subcontrol-position:  top center;
}
#panel
{
	border: 2px solid black;
	border-radius: 4px;
	background-color: rgba(61, 56, 70,150);
}
#start
{
	border: 1px solid silver;
	border-radius: 4px;
	color: white;
	background-color: rgba(38, 162, 105,150);
	padding: 4px;
}
#stop
{
	border: 1px solid silver;
	border-radius: 4px;
	color: white;
	background-color: rgba(192, 28, 40,150);
	padding: 4px;
}
#start:disabled,#stop:disabled
{
	background-color: rgba(154, 153, 150,100);
}

QLabel
{
	color: silver;
}
#running
{
	color: gray;
	font-weight: bold;
	image-position: right;
}
#running:enabled
{
	color: white;
	image: url(:/TREPEL/resources/green-led.png);
	image-position: right;
}
#emergency:enabled
{
	color: gray;
	font-weight: bold;
}
#emergency:enabled
{
	color: red;
	image: url(:/TREPEL/resources/red-led.png);
	image-position: left;
}
#preferences
{
	border: 1px none;
}</string>
